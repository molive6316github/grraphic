# Supabase Configuration (Required)
# These are automatically set when using the Supabase integration
# For manual setup, get from: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Alternative variable names (also supported)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI Configuration (Required for design analysis)
# Get from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Groq AI Configuration (Optional - used for Agent Mode & Gradi chat assistant)
# Provides access to multiple models: Llama 3.3 70B, Llama 3.1 70B, Mixtral 8x7B, Gemma2 9B
# Get from: https://console.groq.com/keys
VITE_GROQ_API_KEY=your-groq-api-key-here

# Stripe Configuration (Optional - only needed for payments)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key-here

# Pixabay Image Search (Optional - used in Boxt design editor)
# Get from: https://pixabay.com/api/docs/
VITE_PIXABAY_API_KEY=your-pixabay-api-key-here

# Flaticon Icon Search (Optional - used in Boxt design editor)
# Get from: https://developer.flaticon.com/
VITE_FLATICON_API_KEY=your-flaticon-api-key-here
VITE_FLATICON_WEBHOOK_SECRET=your-flaticon-webhook-secret-here

# Encryption Secret (Optional - used to encrypt stored analysis data)
VITE_ENCRYPTION_SECRET=your-random-secret-here
